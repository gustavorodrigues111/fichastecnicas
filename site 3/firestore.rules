rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Regra global: qualquer um lê, só admin escreve
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'gustavo@quibebe.com.br';
    }
  }
}
