rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // SCHEMA v2
    // ============================================================
    // /platform_users/{uid}       — consultoria: master, staff
    // /clientes/{cid}/team/{uid}  — equipe do restaurante: dono, admin, op
    // /auth_index/{uid}           — { type: 'platform' | 'restaurant', cids:[...] }
    // /pending_users/{slug}       — fila de pré-cadastros (legado, ainda usada)
    // /clientes/{cid}             — restaurante
    // /clientes/{cid}/dishes,insumos,config,production_plans — dados
    // /users/{uid} e /pending_users (legados pre-v2) — leitura/escrita só master enquanto não removidos
    // ============================================================

    // ---------- helpers ----------
    function isSignedIn() { return request.auth != null; }
    function authIdx() { return get(/databases/$(database)/documents/auth_index/$(request.auth.uid)).data; }
    function hasAuthIdx() { return exists(/databases/$(database)/documents/auth_index/$(request.auth.uid)); }
    function platformDoc() { return get(/databases/$(database)/documents/platform_users/$(request.auth.uid)).data; }
    function teamDoc(cid) { return get(/databases/$(database)/documents/clientes/$(cid)/team/$(request.auth.uid)).data; }

    function isPlatformUser() {
      return isSignedIn() && hasAuthIdx() && authIdx().type == 'platform';
    }
    function isMaster() {
      return isSignedIn() && (
        request.auth.token.email == 'gustavo@quibebe.com.br'
        || (isPlatformUser() && platformDoc().role == 'master')
      );
    }
    function isStaff() {
      return isPlatformUser() && platformDoc().role == 'staff';
    }
    function isStaffOf(cid) {
      return isStaff() && (platformDoc().clienteIds is list) && (cid in platformDoc().clienteIds);
    }
    function isRestaurantUserOf(cid) {
      return isSignedIn() && hasAuthIdx()
        && authIdx().type == 'restaurant'
        && (authIdx().cids is list) && (cid in authIdx().cids);
    }
    function isDonoOf(cid) {
      return isRestaurantUserOf(cid)
        && exists(/databases/$(database)/documents/clientes/$(cid)/team/$(request.auth.uid))
        && teamDoc(cid).role == 'dono';
    }
    function isAdminOf(cid) {
      return isRestaurantUserOf(cid)
        && exists(/databases/$(database)/documents/clientes/$(cid)/team/$(request.auth.uid))
        && teamDoc(cid).role == 'admin';
    }
    function isOpOf(cid) {
      return isRestaurantUserOf(cid)
        && exists(/databases/$(database)/documents/clientes/$(cid)/team/$(request.auth.uid))
        && teamDoc(cid).role == 'op';
    }
    // Quem pode ver o restaurante (todos os perfis com acesso)
    function hasClienteAccess(cid) {
      return isMaster() || isStaffOf(cid) || isRestaurantUserOf(cid);
    }
    // Quem vê preços de insumos: master, staff, dono, admin (não op)
    function canSeeInsumos(cid) {
      return isMaster() || isStaffOf(cid) || isDonoOf(cid) || isAdminOf(cid);
    }

    function onlyPriceFields() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['price', 'unit']);
    }
    function onlyDishPricingFields() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['target_cmv', 'sale_price', 'markup']);
    }
    function onlyInactiveFields() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['inactive', 'inactivatedAt', 'inactivatedBy']);
    }
    function clienteCanUpdateDish() {
      return resource.data.locked != true
        || resource.data.lockedBy != 'consultoria'
        || onlyDishPricingFields()
        || (resource.data.createdBy == 'cliente' && onlyInactiveFields());
    }

    // ============================================================
    // /auth_index — índice. Self-read + master full.
    // ============================================================
    match /auth_index/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isMaster());
      // Self-create no primeiro login (bootstrap do master OU claim de pending)
      allow create: if isSignedIn() && request.auth.uid == uid
                    && (
                      // bootstrap master
                      (request.auth.token.email == 'gustavo@quibebe.com.br'
                       && request.resource.data.type == 'platform')
                      // claim de pending (precisa ter pending matching o slug do email)
                      || (request.resource.data.type == 'restaurant'
                          && request.resource.data.cids is list)
                    );
      // Master gerencia tudo
      allow create, update, delete: if isMaster();
      // Dono/Master/Staff podem CRIAR auth_index de um novo membro convidado
      allow create: if isSignedIn() && hasAuthIdx()
                    && request.resource.data.type == 'restaurant'
                    && request.resource.data.cids is list
                    && request.resource.data.cids.size() >= 1
                    && (isMaster() || isDonoOf(request.resource.data.cids[0]) || isStaffOf(request.resource.data.cids[0]));
    }

    // ============================================================
    // /platform_users — consultoria (master, staff). Só master gerencia.
    // ============================================================
    match /platform_users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isMaster());
      allow list: if isMaster();
      // Self-update limitado (mustChangePassword off + passwordChangedAt)
      allow update: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['mustChangePassword', 'passwordChangedAt']);
      // Master gerencia
      allow create, update, delete: if isMaster();
      // Bootstrap master (self-create no 1º login)
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.auth.token.email == 'gustavo@quibebe.com.br'
                    && request.resource.data.role == 'master';
    }

    // ============================================================
    // /pending_users — fila de convites pendentes
    // ============================================================
    match /pending_users/{slug} {
      // Master e dono/staff podem ler+criar pré-cadastros
      allow read, write: if isMaster();
      // Próprio user lê seu pending no login (pelo email)
      allow read: if isSignedIn() && resource.data.email == request.auth.token.email;
      // O próprio user deleta seu pending após claim
      allow delete: if isSignedIn() && resource.data.email == request.auth.token.email;
      // Dono cria/atualiza/deleta pré-cadastros do restaurante dele
      allow create, update: if isSignedIn()
                            && request.resource.data.cid is string
                            && request.resource.data.role in ['admin', 'op']
                            && (isMaster() || isDonoOf(request.resource.data.cid));
      allow delete: if isSignedIn()
                    && resource.data.cid is string
                    && (isMaster() || isDonoOf(resource.data.cid));
      // LIST: master, qualquer signed-in (rule frouxa por causa de rules-as-filters; app filtra)
      allow list: if isSignedIn();
    }

    // ============================================================
    // /clientes — restaurantes
    // ============================================================
    match /clientes/{cid} {
      allow read: if hasClienteAccess(cid);
      allow list: if isSignedIn(); // app filtra por acesso depois
      allow create, update, delete: if isMaster();

      // ---------- /clientes/{cid}/team — equipe do restaurante ----------
      match /team/{uid} {
        // Quem tem acesso ao cid pode ver a equipe inteira
        allow read, list: if hasClienteAccess(cid);
        // Master, staff do cid e dono do cid gerenciam equipe
        allow create, update, delete: if isMaster() || isStaffOf(cid) || isDonoOf(cid);
        // Próprio user lê seu doc
        allow read: if isSignedIn() && request.auth.uid == uid;
      }

      // ---------- dishes ----------
      match /dishes/{dishId} {
        allow read: if hasClienteAccess(cid);
        allow create: if isMaster() || isStaffOf(cid)
                      || ((isDonoOf(cid) || isAdminOf(cid))
                          && request.resource.data.lockedBy != 'consultoria');
        allow delete: if isMaster() || isStaffOf(cid)
                      || (isDonoOf(cid) && resource.data.inactive == true);
        allow update: if isMaster() || isStaffOf(cid)
                      || ((isDonoOf(cid) || isAdminOf(cid)) && clienteCanUpdateDish());
      }

      // ---------- insumos ----------
      match /insumos/{insumoId} {
        allow read: if canSeeInsumos(cid);
        allow create, delete: if isMaster() || isStaffOf(cid);
        allow update: if isMaster() || isStaffOf(cid)
                      || ((isDonoOf(cid) || isAdminOf(cid)) && onlyPriceFields());
      }

      // ---------- config ----------
      match /config/{configId} {
        allow read: if hasClienteAccess(cid);
        allow write: if isMaster() || isStaffOf(cid);
      }

      // ---------- production_plans ----------
      match /production_plans/{planId} {
        allow read: if hasClienteAccess(cid);
        allow create: if isMaster() || isStaffOf(cid) || isDonoOf(cid) || isAdminOf(cid);
        // Drafts/ready podem ser editados/deletados por quem cria (master/staff/dono/admin)
        // Finalized: só master/staff podem mexer (histórico imutável pro lado do cliente)
        allow update: if isMaster() || isStaffOf(cid)
                      || ((isDonoOf(cid) || isAdminOf(cid))
                          && resource.data.status != 'finalized');
        allow delete: if isMaster() || isStaffOf(cid)
                      || ((isDonoOf(cid) || isAdminOf(cid))
                          && resource.data.status != 'finalized');
      }

      // ---------- production_templates ----------
      match /production_templates/{templateId} {
        allow read: if hasClienteAccess(cid);
        allow create, update, delete: if isMaster() || isStaffOf(cid) || isDonoOf(cid) || isAdminOf(cid);
      }

      // ---------- estoque (legado) ----------
      match /stock_templates/{tid} {
        allow read: if hasClienteAccess(cid);
        allow create, update, delete: if isMaster() || isStaffOf(cid) || isDonoOf(cid);
      }
      match /stock_counts/{countId} {
        allow read: if hasClienteAccess(cid);
        allow create: if hasClienteAccess(cid)
          && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if isMaster() || isStaffOf(cid) || isDonoOf(cid);
        match /logs/{logId} {
          allow read: if hasClienteAccess(cid);
          allow create: if hasClienteAccess(cid)
            && request.resource.data.user.uid == request.auth.uid;
          allow update, delete: if false;
        }
      }
    }

  }
}
