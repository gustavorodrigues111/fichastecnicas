rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isMaster() {
      // Master: static email OR role=master on user doc
      return isSignedIn() && (
        request.auth.token.email == 'gustavo@quibebe.com.br'
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && userDoc().role == 'master')
      );
    }
    function hasClienteAccess(cid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (userDoc().role == 'master'
            || (userDoc().clienteIds is list && userDoc().clienteIds.hasAny([cid])));
    }
    // Equipe só lê cardápio/insumos se tiver a permissão
    function canReadCardapio(cid) {
      return hasClienteAccess(cid)
        && (userDoc().role != 'equipe' || equipeHasPerm('can_view_cardapio'));
    }
    function canReadInsumos(cid) {
      return hasClienteAccess(cid)
        && (userDoc().role != 'equipe' || equipeHasPerm('can_view_insumos'));
    }
    function isStaffOf(cid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role in ['master', 'staff']
        && (userDoc().role == 'master' || userDoc().clienteIds.hasAny([cid]));
    }
    function isClienteUserOf(cid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == 'cliente'
        && userDoc().clienteIds.hasAny([cid]);
    }
    function isEquipeOf(cid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == 'equipe'
        && userDoc().clienteIds.hasAny([cid]);
    }
    function equipeHasPerm(perm) {
      return userDoc().permissions != null && userDoc().permissions[perm] == true;
    }
    // Acesso a estoque (gestão): master/staff/cliente do restaurante; equipe com can_manage_contagem
    function canManageStockOf(cid) {
      return isStaffOf(cid) || isClienteUserOf(cid)
        || (isEquipeOf(cid) && equipeHasPerm('can_manage_contagem'));
    }
    // Quem pode editar contagem já criada
    function canEditStockCount(cid) {
      return canManageStockOf(cid)
        || (isEquipeOf(cid) && equipeHasPerm('can_edit_contagem'));
    }
    // Quem pode criar/editar templates
    function canManageStockTemplates(cid) {
      return isStaffOf(cid) || isClienteUserOf(cid)
        || (isEquipeOf(cid) && equipeHasPerm('can_manage_templates'));
    }
    function onlyPriceFields() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['price', 'unit']);
    }
    function onlyDishPricingFields() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['target_cmv']);
    }

    // ---------- users collection ----------
    match /users/{uid} {
      // Read own doc or master reads all
      allow read: if isSignedIn() && (request.auth.uid == uid || isMaster());
      // Create self as master (bootstrap) — only if email matches master
      allow create: if isSignedIn()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'master'
                    && request.auth.token.email == 'gustavo@quibebe.com.br';
      // Master creates any user doc
      allow create: if isMaster();
      // Master updates any; self update limited
      allow update: if isMaster();
      allow delete: if isMaster();
    }

    // ---------- clientes (top-level) ----------
    match /clientes/{cid} {
      allow read: if hasClienteAccess(cid);
      allow create, update, delete: if isMaster();

      // dishes subcollection
      match /dishes/{dishId} {
        allow read: if canReadCardapio(cid);
        allow create, delete: if isStaffOf(cid);
        // Staff can update anything; cliente can only update target_cmv (pricing)
        allow update: if isStaffOf(cid) || (isClienteUserOf(cid) && onlyDishPricingFields());
      }

      // insumos subcollection
      match /insumos/{insumoId} {
        allow read: if canReadInsumos(cid);
        allow create, delete: if isStaffOf(cid);
        // Staff can update anything; cliente can only update price/unit
        allow update: if isStaffOf(cid) || (isClienteUserOf(cid) && onlyPriceFields());
      }

      // config subcollection
      match /config/{configId} {
        allow read: if hasClienteAccess(cid);
        allow write: if isStaffOf(cid);
      }

      // ------- Módulo de Estoque -------
      // Templates de contagem
      match /stock_templates/{tid} {
        allow read: if hasClienteAccess(cid);
        allow create, update, delete: if canManageStockTemplates(cid);
      }
      // Contagens enviadas
      match /stock_counts/{countId} {
        // Leitura: quem gere vê tudo; equipe só vê as que ela criou
        allow read: if canManageStockOf(cid)
          || (isEquipeOf(cid) && resource.data.authorUid == request.auth.uid);
        // Criar: qualquer um com acesso ao cliente (incluindo equipe default)
        allow create: if hasClienteAccess(cid)
          && request.resource.data.authorUid == request.auth.uid;
        // Editar: quem pode editar contagem
        allow update: if canEditStockCount(cid);
        // Deletar: só quem pode gerir
        allow delete: if canManageStockOf(cid);

        // Logs (subcoleção) — append-only
        match /logs/{logId} {
          allow read: if hasClienteAccess(cid);
          allow create: if hasClienteAccess(cid)
            && request.resource.data.user.uid == request.auth.uid;
          allow update, delete: if false; // logs imutáveis
        }
      }
    }
  }
}
