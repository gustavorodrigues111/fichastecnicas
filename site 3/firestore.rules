rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function hasUserDoc() { return exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isMaster() {
      return isSignedIn() && (
        request.auth.token.email == 'gustavo@quibebe.com.br'
        || (hasUserDoc() && userDoc().role == 'master')
      );
    }
    function hasClienteAccess(cid) {
      return isSignedIn() && hasUserDoc()
        && (userDoc().role == 'master'
            || (userDoc().clienteIds is list && userDoc().clienteIds.hasAny([cid])));
    }
    function isStaffOf(cid) {
      return isSignedIn() && hasUserDoc()
        && userDoc().role in ['master', 'staff']
        && (userDoc().role == 'master' || userDoc().clienteIds.hasAny([cid]));
    }
    // Cliente (dono): role=='cliente'
    function isClienteOwnerOf(cid) {
      return isSignedIn() && hasUserDoc()
        && userDoc().role == 'cliente'
        && userDoc().clienteIds.hasAny([cid]);
    }
    // Equipe Admin do Cliente: role=='cliente_admin' OU role=='equipe' com can_view_insumos
    function isClienteAdminOf(cid) {
      return isSignedIn() && hasUserDoc()
        && userDoc().clienteIds.hasAny([cid])
        && (
          userDoc().role == 'cliente_admin'
          || (userDoc().role == 'equipe'
              && userDoc().permissions != null
              && userDoc().permissions.can_view_insumos == true)
        );
    }
    // Equipe Operacional: role=='cliente_op' OU role=='equipe' sem can_view_insumos
    function isClienteOpOf(cid) {
      return isSignedIn() && hasUserDoc()
        && userDoc().clienteIds.hasAny([cid])
        && (
          userDoc().role == 'cliente_op'
          || (userDoc().role == 'equipe'
              && (userDoc().permissions == null
                  || userDoc().permissions.can_view_insumos != true))
        );
    }
    // Qualquer perfil do lado do cliente (todos veem cardápio e produção)
    function isAnyClienteSideOf(cid) {
      return isClienteOwnerOf(cid) || isClienteAdminOf(cid) || isClienteOpOf(cid);
    }
    // Quem vê preços: master, staff, cliente (dono) e cliente_admin
    function canSeeInsumosOf(cid) {
      return isStaffOf(cid) || isClienteOwnerOf(cid) || isClienteAdminOf(cid);
    }
    // Quem edita preços
    function canEditInsumoPriceOf(cid) {
      return isStaffOf(cid) || isClienteOwnerOf(cid) || isClienteAdminOf(cid);
    }
    function onlyPriceFields() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['price', 'unit']);
    }
    function onlyDishPricingFields() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['target_cmv']);
    }
    function onlyInactiveFields() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['inactive', 'inactivatedAt', 'inactivatedBy']);
    }
    // Update da ficha pelo cliente (dono/admin): permitido SE
    //   - a ficha não está locked, OU
    //   - a ficha foi locked pelo próprio lado do cliente (lockedBy != 'consultoria'), OU
    //   - o update afeta só target_cmv (pricing), OU
    //   - o update afeta só inactive/inactivatedAt/inactivatedBy E a ficha é do cliente
    function clienteCanUpdateDish() {
      return resource.data.locked != true
        || resource.data.lockedBy != 'consultoria'
        || onlyDishPricingFields()
        || (resource.data.createdBy == 'cliente' && onlyInactiveFields());
    }
    // Usuário desativado é bloqueado em tudo (exceto leitura do próprio doc)
    function userIsActive() {
      return hasUserDoc() && (userDoc().disabled != true);
    }

    // ---------- users collection ----------
    match /users/{uid} {
      // GET (leitura de um doc específico): regra completa por doc.
      // Próprio user, master, OU cliente (dono) lendo doc onde clienteIds cruza com o dele.
      allow get: if isSignedIn() && (
        request.auth.uid == uid
        || isMaster()
        || (
          hasUserDoc()
          && userDoc().role == 'cliente'
          && resource.data.clienteIds is list
          && resource.data.clienteIds.hasAny(userDoc().clienteIds)
        )
      );
      // LIST (query): o Firestore não casa hasAny(get()) com array-contains-any
      // (rules-as-filters precisa de expressão estática). Aceitamos LIST de master
      // e de cliente (dono) — o app sempre passa a query filtrada por clienteIds.
      // Risco: cliente_dono malicioso poderia listar TODOS users via DevTools;
      // mitigação: nenhum dado sensível (sem senha) e contexto de consultoria controlada.
      allow list: if isSignedIn() && hasUserDoc()
                  && (userDoc().role == 'master' || userDoc().role == 'cliente')
                  && userDoc().clienteIds is list;
      // Bootstrap do master (auto-criação no primeiro login do master email)
      allow create: if isSignedIn()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'master'
                    && request.auth.token.email == 'gustavo@quibebe.com.br';
      // Self-claim via pending_users: usuário pré-cadastrado pelo master cria seu
      // próprio doc no primeiro login. Exige: email do token bate, role != master,
      // marcado como claimedFromPending, e existe um pending_users com o slug
      // referenciado (validação cruzada — não dá pra forjar sem pending real).
      allow create: if isSignedIn()
                    && request.auth.uid == uid
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.role != 'master'
                    && request.resource.data.claimedFromPending == true
                    && request.resource.data.claimedFromPendingSlug is string
                    && exists(/databases/$(database)/documents/pending_users/$(request.resource.data.claimedFromPendingSlug));
      // Self-update limitado: só o próprio user pode tirar mustChangePassword e setar passwordChangedAt
      allow update: if isSignedIn()
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['mustChangePassword', 'passwordChangedAt']);
      // Cliente (dono) gerencia membros da equipe dos restaurantes dele:
      // - Pode criar usuários cliente_admin/cliente_op com clienteIds nos restaurantes dele
      // - Pode atualizar (promover/rebaixar entre admin/op, desativar, reativar)
      allow create: if isSignedIn()
                    && hasUserDoc()
                    && userDoc().role == 'cliente'
                    && request.resource.data.role in ['cliente_admin', 'cliente_op']
                    && request.resource.data.clienteIds is list
                    && request.resource.data.clienteIds.hasAny(userDoc().clienteIds);
      allow update: if isSignedIn()
                    && hasUserDoc()
                    && userDoc().role == 'cliente'
                    && resource.data.clienteIds is list
                    && resource.data.clienteIds.hasAny(userDoc().clienteIds)
                    && request.resource.data.role in ['cliente_admin', 'cliente_op', 'equipe']
                    && request.resource.data.clienteIds.hasAny(userDoc().clienteIds);
      // Master cria/atualiza/deleta qualquer user
      allow create, update, delete: if isMaster();
    }

    // ---------- pending_users collection (pré-cadastro por email) ----------
    // Doc ID: slugified email. Quando o user loga, app migra esse doc pra users/{uid}
    match /pending_users/{slug} {
      // Master gerencia todos
      allow read, create, update, delete: if isMaster();
      // O próprio user (no login) lê seu pending pelo email no token
      allow read: if isSignedIn()
                  && resource.data.email == request.auth.token.email;
      // O próprio user pode deletar seu pending (após migração pra users/{uid})
      allow delete: if isSignedIn()
                    && resource.data.email == request.auth.token.email;
    }

    // ---------- clientes (top-level) ----------
    match /clientes/{cid} {
      allow read: if hasClienteAccess(cid);
      allow create, update, delete: if isMaster();

      // ---------- dishes (fichas) ----------
      match /dishes/{dishId} {
        // Leitura: qualquer pessoa do cliente (todos os perfis veem fichas)
        allow read: if hasClienteAccess(cid);
        // Criação:
        //   - master/staff: sempre
        //   - cliente (dono/admin): ficha não pode nascer locked pela consultoria
        //                           (pode nascer desbloqueada OU locked como 'cliente')
        allow create: if isStaffOf(cid)
                      || ((isClienteOwnerOf(cid) || isClienteAdminOf(cid))
                          && request.resource.data.lockedBy != 'consultoria');
        // Exclusão:
        //   - master/staff: sempre
        //   - cliente DONO (não admin): qualquer ficha inativada do restaurante dele
        allow delete: if isStaffOf(cid)
                      || (isClienteOwnerOf(cid) && resource.data.inactive == true);
        // Update:
        //   - staff/master: tudo
        //   - cliente (dono/admin): se ficha NÃO está locked OU lockedBy != consultoria,
        //                           OU se update afeta só target_cmv (pricing)
        allow update: if isStaffOf(cid)
                      || ((isClienteOwnerOf(cid) || isClienteAdminOf(cid)) && clienteCanUpdateDish());
      }

      // ---------- insumos ----------
      match /insumos/{insumoId} {
        // Leitura: master/staff, cliente (dono), cliente_admin (perfis que veem preço)
        // cliente_op NÃO vê insumos (sem preços)
        allow read: if canSeeInsumosOf(cid);
        allow create, delete: if isStaffOf(cid);
        // Update:
        //   - staff/master: tudo
        //   - cliente / cliente_admin: só price/unit
        allow update: if isStaffOf(cid)
                      || ((isClienteOwnerOf(cid) || isClienteAdminOf(cid)) && onlyPriceFields());
      }

      // ---------- config ----------
      match /config/{configId} {
        allow read: if hasClienteAccess(cid);
        allow write: if isStaffOf(cid);
      }

      // ---------- production_plans (histórico de planejamentos finalizados) ----------
      match /production_plans/{planId} {
        // Leitura: qualquer pessoa do cliente vê o histórico
        allow read: if hasClienteAccess(cid);
        // Criação: master/staff, cliente (dono), cliente_admin
        allow create: if isStaffOf(cid) || isClienteOwnerOf(cid) || isClienteAdminOf(cid);
        // Update/delete: só staff/master (histórico imutável pros perfis do cliente)
        allow update, delete: if isStaffOf(cid);
      }

      // ---------- estoque (legado — mantido caso reative) ----------
      match /stock_templates/{tid} {
        allow read: if hasClienteAccess(cid);
        allow create, update, delete: if isStaffOf(cid) || isClienteOwnerOf(cid);
      }
      match /stock_counts/{countId} {
        allow read: if hasClienteAccess(cid);
        allow create: if hasClienteAccess(cid)
          && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if isStaffOf(cid) || isClienteOwnerOf(cid);

        match /logs/{logId} {
          allow read: if hasClienteAccess(cid);
          allow create: if hasClienteAccess(cid)
            && request.resource.data.user.uid == request.auth.uid;
          allow update, delete: if false;
        }
      }
    }
  }
}
